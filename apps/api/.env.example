# Environment
ENVIRONMENT=development

# Database (for local development)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=justadrop_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/justadrop_db

# API
API_PORT=8000
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32

# pgAdmin
PGADMIN_EMAIL=admin@justadrop.xyz
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
