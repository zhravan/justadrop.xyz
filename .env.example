# ==================================
# JustADrop Environment Configuration
# ==================================

# ----------------------------------
# Local Development
# ----------------------------------
SITE_NAME=justadrop.local
ADMIN_PASSWORD=admin
DB_TYPE=postgres
PYTHON_VERSION=python3.11
FRAPPE_BRANCH=version-15
DEVELOPER_MODE=1

# ----------------------------------
# Production Configuration (Supabase)
# ----------------------------------
# Uncomment and configure when deploying to production

# Supabase Project URL
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role Key (keep secret!)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Database URLs
# DATABASE_URL="postgresql://postgres:password@host:6543/postgres?pgbouncer=true"
# DIRECT_DATABASE_URL="postgresql://postgres:password@host:5432/postgres"
